{
  "compilerOptions": {
    /* File Layout: Defining the Boundaries of the Box */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Environment Settings: The Law of Modern Syntax */
    "module": "NodeNext",
    "target": "ESNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext", "DOM"], 

    /* Other Outputs: The Audit Trail */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Stricter Typechecking: The No-Empathy Guard */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* Recommended Options for the Narrow Path */
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "skipLibCheck": true,
    "moduleDetection": "force",
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}